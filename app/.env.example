# Calimero KV Store - Environment Variables
#
# Copy this file to .env and fill in values from `meroctl dev start` output.
# Values marked with ← are stable across rebuilds when using dev mode.

VITE_NODE_URL=http://localhost:2428
VITE_RPC_PATH=/jsonrpc
VITE_NEAR_ENVIRONMENT=testnet

# From `meroctl dev start` output (stable with dev key) ←
VITE_APPLICATION_ID=
VITE_CONTEXT_ID=

# Only needed for registry-based flow (not needed in dev mode)
# VITE_PACKAGE_NAME=com.calimero.kv-store
# VITE_REGISTRY_URL=http://localhost:8082
