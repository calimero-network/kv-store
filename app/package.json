{
  "name": "kv-store-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@calimero-network/mero-icons": "^0.0.4",
    "@calimero-network/mero-react": "^1.0.2",
    "@calimero-network/mero-ui": "^0.3.6",
    "axios": "^1.15.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.1.11"
  },
  "devDependencies": {
    "@calimero-network/abi-codegen": "^1.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-refresh": "^0.4.7",
    "prettier": "3.3.2",
    "typescript": "^5.5.0",
    "vite": "^7.1.11",
    "vite-plugin-node-polyfills": "^0.24.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "concurrently \"pnpm:lint:*(!fix)\"",
    "lint:src": "eslint . --ext .ts,.tsx src --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\"",
    "lint:src:fix": "eslint . --ext .ts,.tsx --fix src",
    "preview": "vite preview",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d build",
    "prettier": "exec prettier . --write",
    "codegen": "calimero-abi-codegen -i ../logic/res/abi.json -o src/generated --client-name KvStoreClient"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
